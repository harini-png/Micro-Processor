		OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DW 0004H,0005H,0003H,0006H
ARRAY1 DW 0000H,0000H
COUNT DB 04H
DATA ENDS
CODE SEGMENT	
	ASSUME CS:CODE,DS:DATA
	MOV AX,DATA
	MOV DS,AX
	LEA SI,ARRAY
	LEA DI,ARRAY1
	MOV CH,03H
L1:	MOV AX,[SI]
	MOV BX,AX
	DIV CH
	CMP AH,00H
	JNZ L2
